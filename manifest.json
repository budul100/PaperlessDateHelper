{
  "manifest_version": 3,
  "name": "Paperless Date Helper",
  "version": "1.1",
  "description": "Adds alternative date interpretations and copies date suggestions to custom date fields in Paperless-ngx.",
  "browser_specific_settings": {
    "gecko": {
      "id": "paperless-date-helper@budul.de",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://*/*"
  ]
}